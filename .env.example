# NEXO UAPA — Variables de entorno
# Copia este archivo como .env y completa los valores

# Base de datos — SQLite para desarrollo (ya configurado en schema.prisma)
# Para producción en PostgreSQL, descomenta y ajusta:
# DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/nexouapa"

# NextAuth — genera un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# Redis para Pomodoro en tiempo real (opcional en desarrollo)
# REDIS_URL="redis://localhost:6379"
